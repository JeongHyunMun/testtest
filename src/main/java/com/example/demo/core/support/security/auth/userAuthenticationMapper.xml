<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.core.support.security.auth.UserAuthenticationMapper">
    <!-- 로그인 -->
    <select id="getUserAccount" resultType="com.example.demo.user.User">
        SELECT * FROM USER
        WHERE USER_ID= #{user_id}
    </select>

</mapper>